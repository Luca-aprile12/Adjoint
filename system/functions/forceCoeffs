#include 	"../../initialConditions"

libs ( "libforces.so" );

DP_forceCoeffs
{
    type        forceCoeffsModified;

    libs ( "forceCoeffsModified.so" );

    writeControl    timeStep;
    timeInterval    1;

    log         true;

    patches     ( "DP_.*" );
    rhoName     rho;
    rhoInf      $rho;          // Redundant for incompressible
    rho         rhoInf;     // Indicates incompressible
    liftDir     $lift;
    dragDir     $drag;
    CofR        $CR;  // Axle midpoint on ground
    pitchAxis   $pitch;
    magUInf     $magU;
    lRef        $wb;        // Wheelbase length
    Aref        $A;        // Estimated
    porosity    false;
    //coefficients (Cl Cd CmPitch);


}
