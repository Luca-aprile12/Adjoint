// CORRETTO: rimossa la lib forceCoeffsModified.so che non esiste e causa
// warning su tutti i 12 processor ad ogni step (decompose, solve, reconstruct)
// libs ( "forceCoeffsModified.so" );

#include        "../initialConditions"

application     adjointOptimisationFoam;

startFrom       latestTime;

startTime       0;

stopAt          endTime;

endTime         35;

deltaT          1;

writeControl    timeStep;

writeInterval   1;

// CORRETTO: purgeWrite 0 per mantenere tutti i timestep scritti.
// Con purgeWrite 1 si perdeva il timestep 0 (baseline) e non era possibile
// confrontare geometria iniziale e ottimizzata in ParaView.
purgeWrite      0;

writeFormat     binary;

writePrecision  6;

writeCompression off;

timeFormat      general;

timePrecision   6;

runTimeModifiable true;

