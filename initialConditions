FoamFile
{
    version     2.0;
    format      ascii;
    class       IOobject;
    location    "0";
    object      initialConditions;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

np      	      12;


//for SIMPLE
iterations           60; //1000 
writeStep            10; //250

turbModel            kOmegaSST;

flowVelocity         (16 0 0);
pressure             0;
turbulentKE          0.085;
turbulentOmega       1.78;


rho                  1.225;
lift                 (0 0 1);
drag                 (1 0 0);
CR                   (0 0.765 0);	// (1.08 0 0.145)
pitch                (0 1 0);
magU                 16;
wb                   1.53;
A                    1;


FLCenter           (0 -0.6225613 0.1981985);
FLaxis                 (0 -0.9998476952 0.0174524064);		// camber -1
FLomega                 80.2342;

FRCenter           (0 0.6225613 0.1981985);
FRaxis                 (0 0.9998476952 0.0174524064);   
FRomega                 -80.2342;

RLCenter           (1.53 -0.6225613 0.1981985);
RLaxis                 (0 -0.9998476952 0.0174524064);       	// camber -1
RLomega                80.2342;

RRCenter           (1.53 0.6225613 0.1981985);
RRaxis                 (0 0.9998476952 0.0174524064);
RRomega                 -80.2342;




// ============ Relaxation Factors ===============
/*pRF		     0.3;
URF                  0.7;
kRF                  0.7;
omegaRF              0.7;*/


// ============= FOR snappyHexMesh ====================
inclAngle		150;

// DISTANZE ALA (Solo 3 step per fare veloce)
dist1 			0.02;
ref1 			5;

dist2			0.06;
ref2			4;

dist3 			0.15;
ref3 			3;

// BOX SCIA (Unico box rimasto)
min1                   (-1.0 0.0 0.0);
max1                   (1.5 1.0 0.8);
lvl1                   3;

// Refinement levels (Abbassato a 6 per velocità di test)
FW_RefLvl        	(5 6);
FW_feature       	6;

// Layers number
FW_nLayers          5; // Abbassato da 5 a 3
ground_nLayers      3;

// expansion ratios
expansionRatio                  1.1;
expansionRatio_FW               1.15;
expansionRatio_ground           1.3;

// first layer thichkness (m)
firstLayerThickness	            0.001;
firstLayerThickness_FW              0.0003;
firstLayerThickness_ground          0.25;

relativeSizes false;

featureAngle	           130;
slipFeatureAngle            60;
maxThicknessToMedialRatio  1.2;
minMedialAxisAngle         160;
maxFaceThicknessRatio        3;
nSmoothNormals               8;
nSmoothSurfaceNormals        8;
nSmoothThickness            10;
nRelaxIter                  15;

// =========== FOR nearWallFields FUNCTION =============
U_near_d             0.001;
// =========== FOR isoSurfaces FUNCTION =============
Q_isoSurface	10000;
